meta {
  name: CrearMaterial
  type: http
  seq: 1
}

post {
  url: {{url}}/api/v1/catalogo/material
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "nombre": "Cemento Portland tipo II",
    "descripcion": "Saco de 60 kg para hormigón estructural",
    "unidad": "unidad",
    "precio_referencia": "10"
  }
}
